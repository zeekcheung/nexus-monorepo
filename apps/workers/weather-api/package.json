{
  "name": "weather-api",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build:docs": "md2html -i README.md -o public/index.html -t \"Weather API\"",
    "predeploy": "bun run build:docs",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "cf-dbgen:local": "wrangler d1 execute weather-db --local --file=./schema.sql && wrangler types",
    "cf-dbgen:remote": "wrangler d1 execute weather-db --remote --file=./schema.sql",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@hono/zod-validator": "catalog:",
    "dayjs": "catalog:",
    "hono": "catalog:",
    "md2html": "workspace:*",
    "shared": "workspace:*",
    "validators": "workspace:*",
    "zod": "catalog:"
  }
}
