{
  "name": "nexus-monorepo",
  "private": true,
  "description": "A monorepo for personal projects",
  "workspaces": {
    "packages": [
      "apps/**",
      "packages/**"
    ],
    "catalog": {
      "hono": "^4.12.23",
      "electrobun": "^1.18.1",
      "@hono/zod-validator": "^0.8.0",
      "zod": "^4.4.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter './apps/**' dev",
    "start": "bun run --filter './apps/**' start",
    "build": "bun run --filter './**' build",
    "build:apps": "bun run --filter './apps/**' build",
    "build:devtools": "bun run --filter './packages/devtools/**' build",
    "deploy": "bun run --filter './apps/**' deploy",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:affected": "sh ./scripts/test-affected.sh",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --type-aware --fix --fix-suggestions --fix-dangerously",
    "prepare": "husky"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "@cloudflare/workers-types": "^4.20260529.1",
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=22"
  }
}
